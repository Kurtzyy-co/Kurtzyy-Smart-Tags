rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(existingData) {
      return isSignedIn() && existingData.userId == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['id', 'childName', 'contacts', 'tagColor'])
        && data.id is string && data.id.size() <= 128
        && data.childName is string && data.childName.size() <= 100
        && data.tagColor is string && data.tagColor.size() <= 50
        && data.contacts is list && data.contacts.size() <= 10;
    }

    match /profiles/{profileId} {
      allow read: if true; // Publicly readable for scanning tags
      
      allow create: if isValidId(profileId) 
        && isValidProfile(request.resource.data)
        && (!request.resource.data.keys().hasAny(['userId']) || request.resource.data.userId == "" || (isSignedIn() && request.resource.data.userId == request.auth.uid));

      allow update: if isValidId(profileId)
        && isValidProfile(request.resource.data)
        && (
          // If profile has no owner, anyone can edit it, or if it has an owner, only the owner can edit it
          (!resource.data.keys().hasAny(['userId']) || resource.data.userId == "" || isOwner(resource.data))
          && (request.resource.data.userId == resource.data.userId) // Do not let non-owners claim ownership
        );

      allow delete: if isSignedIn() && (
        !resource.data.keys().hasAny(['userId']) || resource.data.userId == "" || isOwner(resource.data)
      );
    }
  }
}
